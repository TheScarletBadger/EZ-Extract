<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Umbra — Upload</title>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0d0d10;
      --surface:   #131318;
      --border:    #2a2a38;
      --purple:    #8b5cf6;
      --purple-dim: #4c1d95;
      --glow:      rgba(139, 92, 246, 0.25);
      --text:      #e8e8f0;
      --muted:     #6b6b80;
      --ring-w:    3px;
    }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      overflow-x: hidden;
    }

    /* ─── subtle noise grain overlay ─── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
    }

    /* ─── radial ambient light behind card ─── */
    body::after {
      content: '';
      position: fixed;
      top: 30%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(139,92,246,0.08) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    }

    /* ─── layout ─── */
    .page {
      position: relative;
      z-index: 1;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 48px 24px 80px;
    }

    /* ─── nav / logo ─── */
    header {
      width: 100%;
      max-width: 760px;
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 72px;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 14px;
      text-decoration: none;
    }

    /* Purple ring — animated slow rotation of gradient arc */
    .logo-ring {
      position: relative;
      width: 42px;
      height: 42px;
      flex-shrink: 0;
    }

    .logo-ring svg {
      width: 100%;
      height: 100%;
    }

    /* Inner dot in the ring */
    .logo-ring::after {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--purple);
      box-shadow: 0 0 10px var(--purple);
    }

    .logo-name {
      font-family: 'Cinzel', serif;
      font-size: 1.55rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      color: var(--purple);
      text-transform: uppercase;
    }

    /* ─── hero text ─── */
    .hero {
      text-align: center;
      margin-bottom: 40px;
      animation: fadeUp 0.7s ease both;
    }

    .hero h1 {
      font-family: 'Cinzel', serif;
      font-size: clamp(1.6rem, 4vw, 2.4rem);
      font-weight: 400;
      letter-spacing: 0.06em;
      margin-bottom: 12px;
    }

    .hero p {
      font-size: 0.95rem;
      color: var(--muted);
      font-weight: 300;
      letter-spacing: 0.02em;
    }

    /* ─── drop zone ─── */
    .drop-zone {
      position: relative;
      width: 100%;
      max-width: 620px;
      border: 1.5px solid var(--border);
      border-radius: 18px;
      background: var(--surface);
      padding: 64px 40px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 18px;
      cursor: pointer;
      transition: border-color 0.25s, box-shadow 0.25s, background 0.25s;
      animation: fadeUp 0.7s 0.15s ease both;
      outline: none;
    }

    /* Corner accent lines */
    .drop-zone::before,
    .drop-zone::after {
      content: '';
      position: absolute;
      width: 24px; height: 24px;
      border-color: var(--purple);
      border-style: solid;
      opacity: 0.5;
      transition: opacity 0.25s;
    }
    .drop-zone::before {
      top: 14px; left: 14px;
      border-width: 2px 0 0 2px;
      border-radius: 4px 0 0 0;
    }
    .drop-zone::after {
      bottom: 14px; right: 14px;
      border-width: 0 2px 2px 0;
      border-radius: 0 0 4px 0;
    }

    .drop-zone:hover,
    .drop-zone.active {
      border-color: var(--purple);
      background: rgba(139, 92, 246, 0.05);
      box-shadow: 0 0 40px var(--glow), inset 0 0 30px rgba(139,92,246,0.04);
    }

    .drop-zone:hover::before,
    .drop-zone:hover::after,
    .drop-zone.active::before,
    .drop-zone.active::after {
      opacity: 1;
    }

    /* Upload icon */
    .upload-icon {
      width: 56px; height: 56px;
      border-radius: 50%;
      border: 1.5px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      transition: border-color 0.25s, box-shadow 0.25s;
    }

    .drop-zone:hover .upload-icon,
    .drop-zone.active .upload-icon {
      border-color: var(--purple);
      box-shadow: 0 0 16px var(--glow);
    }

    .upload-icon svg {
      width: 26px; height: 26px;
      stroke: var(--purple);
      stroke-width: 1.5;
      fill: none;
      transition: transform 0.25s;
    }

    .drop-zone:hover .upload-icon svg {
      transform: translateY(-2px);
    }

    .drop-label {
      font-size: 1rem;
      font-weight: 400;
      color: var(--text);
      letter-spacing: 0.01em;
      text-align: center;
    }

    .drop-label strong {
      color: var(--purple);
      font-weight: 500;
    }

    .drop-sub {
      font-size: 0.78rem;
      color: var(--muted);
      letter-spacing: 0.03em;
    }

    .divider {
      display: flex;
      align-items: center;
      gap: 12px;
      width: 100%;
      max-width: 220px;
    }

    .divider span {
      font-size: 0.72rem;
      color: var(--muted);
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .divider::before, .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .btn-browse {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.82rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--purple);
      background: transparent;
      border: 1px solid var(--purple-dim);
      border-radius: 6px;
      padding: 9px 24px;
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s, box-shadow 0.2s;
    }

    .btn-browse:hover {
      background: rgba(139,92,246,0.12);
      border-color: var(--purple);
      box-shadow: 0 0 12px var(--glow);
    }

    /* Hidden file input */
    #fileInput { display: none; }

    /* ─── file list ─── */
    .file-list {
      width: 100%;
      max-width: 620px;
      margin-top: 24px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .file-item {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 14px 18px;
      display: flex;
      align-items: center;
      gap: 14px;
      animation: fadeUp 0.3s ease both;
    }

    .file-icon {
      width: 32px; height: 32px;
      border-radius: 6px;
      background: rgba(139,92,246,0.12);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }

    .file-icon svg {
      width: 16px; height: 16px;
      stroke: var(--purple);
      stroke-width: 1.8;
      fill: none;
    }

    .file-info { flex: 1; overflow: hidden; }

    .file-name {
      font-size: 0.88rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      color: var(--text);
    }

    .file-size {
      font-size: 0.72rem;
      color: var(--muted);
      margin-top: 2px;
    }

    .file-remove {
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      color: var(--muted);
      transition: color 0.2s;
      display: flex;
    }

    .file-remove:hover { color: #ef4444; }

    .file-remove svg {
      width: 14px; height: 14px;
      stroke: currentColor;
      stroke-width: 2;
      fill: none;
    }

    /* ─── animations ─── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0);    }
    }

    /* ─── footer ─── */
    footer {
      margin-top: auto;
      padding-top: 60px;
      font-size: 0.72rem;
      color: var(--muted);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
  </style>
</head>
<body>
<div class="page">

  <!-- Logo / Nav -->
  <header>
    <a href="#" class="logo">
      <div class="logo-ring">
        <svg viewBox="0 0 42 42" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="ringGrad" x1="0" y1="0" x2="42" y2="42" gradientUnits="userSpaceOnUse">
              <stop offset="0%"   stop-color="#8b5cf6" stop-opacity="1"/>
              <stop offset="40%"  stop-color="#c084fc" stop-opacity="0.8"/>
              <stop offset="100%" stop-color="#4c1d95" stop-opacity="0.1"/>
            </linearGradient>
          </defs>
          <circle cx="21" cy="21" r="18" stroke="url(#ringGrad)" stroke-width="3" stroke-linecap="round"
                  stroke-dasharray="90 24"/>
        </svg>
      </div>
      <span class="logo-name">U<span>m</span>bra</span>
    </a>
  </header>

  <!-- Drop Zone -->
  <div class="drop-zone" id="dropZone" tabindex="0" role="button" aria-label="File drop area">
    <div class="upload-icon">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 16V8M12 8L9 11M12 8L15 11"/>
        <path d="M20 16.7A4 4 0 0 0 18 9h-1.26A8 8 0 1 0 4 16.7"/>
      </svg>
    </div>

    <p class="drop-label">
      <strong>Drag &amp; drop</strong> your files here
    </p>
    <p class="drop-sub">Supports any file type · up to 500 MB</p>

    <div class="divider"><span>or</span></div>

    <button class="btn-browse" id="browseBtn">Browse files</button>

    <input type="file" id="fileInput" multiple />
  </div>

  <!-- File list -->
  <div class="file-list" id="fileList"></div>

  <footer>© 2026 Umbra · All rights reserved</footer>
</div>

<script>
  const dropZone  = document.getElementById('dropZone');
  const fileInput = document.getElementById('fileInput');
  const browseBtn = document.getElementById('browseBtn');
  const fileList  = document.getElementById('fileList');

  browseBtn.addEventListener('click', e => { e.stopPropagation(); fileInput.click(); });
  dropZone.addEventListener('click', () => fileInput.click());

  dropZone.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') fileInput.click(); });

  fileInput.addEventListener('change', () => addFiles(fileInput.files));

  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('active'); });
  dropZone.addEventListener('dragleave', e => { if (!dropZone.contains(e.relatedTarget)) dropZone.classList.remove('active'); });
  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    dropZone.classList.remove('active');
    addFiles(e.dataTransfer.files);
  });

  function fmt(bytes) {
    if (bytes < 1024)        return bytes + ' B';
    if (bytes < 1024 ** 2)   return (bytes / 1024).toFixed(1) + ' KB';
    if (bytes < 1024 ** 3)   return (bytes / 1024 ** 2).toFixed(1) + ' MB';
    return (bytes / 1024 ** 3).toFixed(1) + ' GB';
  }

  function addFiles(fileArr) {
    Array.from(fileArr).forEach(file => {
      const item = document.createElement('div');
      item.className = 'file-item';
      item.innerHTML = `
        <div class="file-icon">
          <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
        <div class="file-info">
          <div class="file-name">${escHtml(file.name)}</div>
          <div class="file-size">${fmt(file.size)}</div>
        </div>
        <button class="file-remove" title="Remove">
          <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>`;
      item.querySelector('.file-remove').addEventListener('click', () => item.remove());
      fileList.appendChild(item);
    });
  }

  function escHtml(str) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
</script>
</body>
</html>
